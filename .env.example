# ============================================================
# CorpAI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA faça commit do arquivo .env no repositório.
# ============================================================

# ─── GERAL ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=corpai

# ─── POSTGRESQL ─────────────────────────────────────────────
POSTGRES_USER=corpai
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_FORTE
POSTGRES_DB=corpai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Banco separado para o Paperless-NGX (mesmo servidor PG)
PAPERLESS_POSTGRES_DB=paperless

# Banco separado para o Zabbix (mesmo servidor PG)
ZABBIX_POSTGRES_DB=zabbix

# Banco separado para o Dify (mesmo servidor PG)
DIFY_POSTGRES_DB=dify

# ─── REDIS ──────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_ESTA_SENHA_REDIS
REDIS_HOST=redis
REDIS_PORT=6379

# ─── OLLAMA ─────────────────────────────────────────────────
# Ollama roda internamente — nunca expor para fora da rede
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:72b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── CHROMADB ───────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=TROQUE_ESTE_TOKEN_CHROMA

# ─── CORPAI BACKEND (FastAPI) ──────────────────────────────
CORPAI_SECRET_KEY=TROQUE_ESTA_CHAVE_SECRETA_JWT_256BITS
CORPAI_ACCESS_TOKEN_EXPIRE_MINUTES=60
CORPAI_REFRESH_TOKEN_EXPIRE_DAYS=7
CORPAI_ADMIN_USERNAME=admin
CORPAI_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_ADMIN

# ─── DIFY ───────────────────────────────────────────────────
DIFY_SECRET_KEY=TROQUE_ESTA_CHAVE_SECRETA_DIFY
DIFY_INIT_PASSWORD=TROQUE_ESTA_SENHA_INIT_DIFY

# Configuração do Dify para usar ChromaDB como vetor store
DIFY_VECTOR_STORE=chromadb

# ─── NGINX PROXY MANAGER ───────────────────────────────────
# Credenciais padrão do NPM (trocar após primeiro login):
# Email: admin@example.com
# Senha: changeme

# ─── GRAFANA ────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_GRAFANA

# ─── ZABBIX ────────────────────────────────────────────────
ZABBIX_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_ZABBIX

# ─── PAPERLESS-NGX ─────────────────────────────────────────
PAPERLESS_SECRET_KEY=TROQUE_ESTA_CHAVE_SECRETA_PAPERLESS
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_PAPERLESS
