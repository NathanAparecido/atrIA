# ============================================================
# atrIA — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# ============================================================

# ---------- PostgreSQL (shared) ----------
POSTGRES_USER=atria
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=atria
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---------- Atria API ----------
ATRIA_JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
ATRIA_JWT_EXPIRATION=7d
ATRIA_API_PORT=3001
ATRIA_BCRYPT_ROUNDS=12

# ---------- SMTP (email) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=atrIA <noreply@yourdomain.com>

# ---------- Dify ----------
DIFY_API_KEY=app-CHANGE_ME_after_creating_app_in_dify
DIFY_API_URL=https://cronnos.netwise.com.br/v1

# ---------- Cohere (LLM) ----------
# Get your key at https://dashboard.cohere.com
COHERE_API_KEY=CHANGE_ME_cohere_api_key

# ---------- Frontend (Vite build-time) ----------
VITE_SELF_HOSTED=true
VITE_API_URL=/api
VITE_APP_NAME=atrIA
VITE_N8N_WEBHOOK_URL=https://n8n.netwise.com.br/webhook/atria
